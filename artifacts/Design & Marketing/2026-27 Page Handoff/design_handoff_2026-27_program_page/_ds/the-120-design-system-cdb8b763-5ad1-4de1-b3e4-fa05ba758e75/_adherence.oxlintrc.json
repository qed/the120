{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/actions/**",
              "components/brand/**",
              "components/content/**",
              "components/crm/**",
              "components/forms/**",
              "ui_kits/marketing-site/**",
              "ui_kits/member-dashboard/**",
              "ui_kits/staff-crm/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Space Grotesk|IBM Plex Mono))/i]",
        "message": "Font not provided by the design system. Available: Space Grotesk, IBM Plex Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|href|onClick|block|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, href, onClick, block, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ink|ghost|white|ghostLight)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ink' | 'ghost' | 'white' | 'ghostLight'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Checkbox'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|checked|onChange|key|ref|className|style|children)$/]",
        "message": "<Checkbox> doesn't accept that prop. Declared props: children, checked, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='DisplayHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|as|size|tone|style|key|ref|className|style|children)$/]",
        "message": "<DisplayHeading> doesn't accept that prop. Declared props: children, as, size, tone, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='DisplayHeading'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:h1|h2|h3|div)$/]",
        "message": "<DisplayHeading> as must be one of 'h1' | 'h2' | 'h3' | 'div'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DisplayHeading'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|dark)$/]",
        "message": "<DisplayHeading> tone must be one of 'light' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FaqItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:question|children|open|onToggle|key|ref|className|style|children)$/]",
        "message": "<FaqItem> doesn't accept that prop. Declared props: question, children, open, onToggle."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|alt|title|index|body|key|ref|className|style|children)$/]",
        "message": "<FeatureCard> doesn't accept that prop. Declared props: image, alt, title, index, body."
      },
      {
        "selector": "JSXOpeningElement[name.name='FilterChip'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|active|onClick|key|ref|className|style|children)$/]",
        "message": "<FilterChip> doesn't accept that prop. Declared props: children, active, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='GroupCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:category|name|blurb|cta|href|key|ref|className|style|children)$/]",
        "message": "<GroupCard> doesn't accept that prop. Declared props: category, name, blurb, cta, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='HeatPips'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|suggested|key|ref|className|style|children)$/]",
        "message": "<HeatPips> doesn't accept that prop. Declared props: value, max, suggested."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|size|key|ref|className|style|children)$/]",
        "message": "<Kicker> doesn't accept that prop. Declared props: children, tone, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Kicker'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:red|blush|muted)$/]",
        "message": "<Kicker> tone must be one of 'red' | 'blush' | 'muted'."
      },
      {
        "selector": "JSXOpeningElement[name.name='PitchCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:kicker|children|dot|action|key|ref|className|style|children)$/]",
        "message": "<PitchCard> doesn't accept that prop. Declared props: kicker, children, dot, action."
      },
      {
        "selector": "JSXOpeningElement[name.name='SeatsDot'] > JSXAttribute > JSXIdentifier[name!=/^(?:remaining|total|tone|key|ref|className|style|children)$/]",
        "message": "<SeatsDot> doesn't accept that prop. Declared props: remaining, total, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='SeatsDot'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:light|onDark)$/]",
        "message": "<SeatsDot> tone must be one of 'light' | 'onDark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Select'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|options|flat|key|ref|className|style|children)$/]",
        "message": "<Select> doesn't accept that prop. Declared props: label, options, flat."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|accent|label|note|key|ref|className|style|children)$/]",
        "message": "<StatCard> doesn't accept that prop. Declared props: value, accent, label, note."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|key|ref|className|style|children)$/]",
        "message": "<StatusPill> doesn't accept that prop. Declared props: children, tone."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatusPill'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:neutral|blue|red|ink|blush|green)$/]",
        "message": "<StatusPill> tone must be one of 'neutral' | 'blue' | 'red' | 'ink' | 'blush' | 'green'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TestimonialCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:quote|name|role|key|ref|className|style|children)$/]",
        "message": "<TestimonialCard> doesn't accept that prop. Declared props: quote, name, role."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|hint|flat|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, hint, flat."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|sublabel|stacked|key|ref|className|style|children)$/]",
        "message": "<Wordmark> doesn't accept that prop. Declared props: tone, sublabel, stacked."
      },
      {
        "selector": "JSXOpeningElement[name.name='Wordmark'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:dark|light)$/]",
        "message": "<Wordmark> tone must be one of 'dark' | 'light'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
